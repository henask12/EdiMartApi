{
  "name": "@edisims/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate": "prisma generate --schema=../../packages/database/prisma/schema.prisma",
    "postinstall": "prisma generate --schema=../../packages/database/prisma/schema.prisma",
