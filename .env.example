# --- Railway: set on EdiMartApi service (Variables), NOT in this file ---
# DATABASE_URL = reference from Postgres service (${{Postgres.DATABASE_URL}})
# JWT_SECRET   = you create this (48+ chars) — never commit the real value

DATABASE_URL="postgresql://user:password@host:5432/railway?schema=public"
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN="8h"
WEB_ORIGIN="https://your-app.vercel.app"
UPLOAD_DIR="./uploads"
PUBLIC_API_URL="https://edimartapi-production.up.railway.app"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Edi's Collection <alerts@yourdomain.com>"
EXPIRY_ALERT_DAYS=7
